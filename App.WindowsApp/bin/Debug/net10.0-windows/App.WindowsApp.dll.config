<?xml version="1.0" encoding="utf-8" ?>
<configuration>
  <startup>
    <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.7.2" />
  </startup>
  <connectionStrings>
    <!--
      IMPORTANT: Change the Data Source to match your SQL Server instance.
      Common values:
        .\SQLEXPRESS   (SQL Server Express)
        (local)        (SQL Server default instance)
        localhost      (same as local)
        DESKTOP-ABC\SQLEXPRESS  (named instance)
    -->
    <add name="BloodBankDB"
         connectionString="Data Source=.\SQLEXPRESS;Initial Catalog=BloodBankDB;Integrated Security=True;Connect Timeout=30;"
         providerName="System.Data.SqlClient" />
  </connectionStrings>
  <appSettings>
    <add key="AppName" value="Blood Bank Management System" />
    <add key="Version" value="1.0" />
  </appSettings>
</configuration>
